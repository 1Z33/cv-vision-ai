# ============================================
# CONFIGURATION BASE DE DONNÉES (PostgreSQL Local)
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:al1234@localhost:5432/cv_vision_ai
# Pour sync operations (Alembic)
SYNC_DATABASE_URL=postgresql://postgres:al1234@localhost:5432/cv_vision_ai

# ============================================
# SÉCURITÉ
# ============================================
SECRET_KEY=ta_cle_secrete_tres_longue_et_aleatoire_ici_min_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# ENVIRONNEMENT
# ============================================
ENVIRONMENT=development
DEBUG=True

# ============================================
# UPLOADS
# ============================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5