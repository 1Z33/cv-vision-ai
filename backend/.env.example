# ========================================
# 🚀 DEPLOYMENT CONFIGURATIONS
# ========================================

# LOCAL DEVELOPMENT (SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./cv_vision_ai.db
# SYNC_DATABASE_URL=sqlite:///./cv_vision_ai.db

# RENDER / PRODUCTION (PostgreSQL)
# Render injecte automatiquement DATABASE_URL depuis la DB PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/db_name
# SYNC_DATABASE_URL=postgresql://user:password@host:5432/db_name

# ========================================
# SECURITY (JWT)
# ========================================
SECRET_KEY=your-secret-key-change-me-immediately-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================================
# ENVIRONMENT
# ========================================
ENVIRONMENT=development  # or "production"
DEBUG=True              # Set to False in production

# ========================================
# FILE UPLOADS
# ========================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ========================================
# NOTES FOR RENDER DEPLOYMENT
# ========================================
# 1. Do NOT commit the real .env file to GitHub
# 2. Render reads variables from:
#    - render.yaml (if present at repo root)
#    - Dashboard Environment Variables
#    - Database connection string (fromDatabase)
#
# 3. Required for production:
#    - Generate strong SECRET_KEY: openssl rand -hex 32
#    - Set ENVIRONMENT=production
#    - Set DEBUG=False
#    - PostgreSQL DATABASE_URL (auto from Render)
